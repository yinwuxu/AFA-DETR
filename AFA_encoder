class C-SimAM(nn.Module):
    """ SimAM: A Parameter-free Attention Module (CVPR 2021) """

    def __init__(self, e_lambda=1e-4):
        super().__init__()
        self.e_lambda = e_lambda

    def forward(self, x):
        # x: [B, C, H, W]
        x_mean = x.mean(dim=(2, 3), keepdim=True)
        x_var = ((x - x_mean) ** 2).mean(dim=(2, 3), keepdim=True)
        attention = (x - x_mean) / (4 * (x_var + self.e_lambda)) + 0.5
        return x * attention


