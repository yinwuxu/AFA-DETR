# Upsample / Downsample (C 方案)
# ===============================
class Upsample(nn.Module):
    def __init__(self, in_channels, out_channels, scale_factor=2):
        super(Upsample, self).__init__()
        self.upsample = nn.Sequential(
            BasicConv(in_channels, out_channels, 1, use_relu=False),
            nn.Upsample(scale_factor=scale_factor, mode='bilinear', align_corners=False)
        )

    def forward(self, x):
        return self.upsample(x)


def DWDown(in_channels, out_channels, stride: int, use_act: bool = False):
    return nn.Sequential(
        BasicConv(in_channels, out_channels, 1, use_relu=use_act),
        nn.Conv2d(out_channels, out_channels, kernel_size=3, stride=stride,
                  padding=1, groups=out_channels, bias=False),
        nn.BatchNorm2d(out_channels),
    )


class Downsample_x2(nn.Module):
    def __init__(self, in_channels, out_channels):
        super(Downsample_x2, self).__init__()
        self.downsample = DWDown(in_channels, out_channels, stride=2, use_act=True)

    def forward(self, x):
        return self.downsample(x)


class Downsample_x4(nn.Module):
    def __init__(self, in_channels, out_channels):
        super(Downsample_x4, self).__init__()
        self.downsample = DWDown(in_channels, out_channels, stride=4, use_act=True)

    def forward(self, x):
        return self.downsample(x)


class ASFF_2(nn.Module):
    def __init__(self, inter_dim=512, gamma=0.1):
        super().__init__()
        self.inter_dim = inter_dim
        self.gamma = gamma
        compress_c = 4

        # 权重生成 (保持不变)
        self.weight_level_1 = BasicConv(inter_dim, compress_c, 1, 1)
        self.weight_level_2 = BasicConv(inter_dim, compress_c, 1, 1)
        self.weight_levels = nn.Conv2d(compress_c * 2, 2, kernel_size=1, stride=1, padding=0)

        self.conv = nn.Sequential(
            nn.Conv2d(inter_dim, inter_dim, 3, 1, 1,
                      groups=inter_dim, bias=False),  # DWConv
            nn.BatchNorm2d(inter_dim),
            nn.SiLU(inplace=True),
            nn.Conv2d(inter_dim, inter_dim, 1, bias=False),  # PWConv
            nn.BatchNorm2d(inter_dim),
        )

    def forward(self, input1, input2):
        level_1_weight_v = self.weight_level_1(input1)
        level_2_weight_v = self.weight_level_2(input2)
        levels_weight_v = torch.cat((level_1_weight_v, level_2_weight_v), 1)
        levels_weight = self.weight_levels(levels_weight_v)

        # ✅ tau=1.0 (默认, 文献推荐)
        levels_weight = F.softmax(levels_weight, dim=1)

        fused = (input1 * levels_weight[:, 0:1] +
                 input2 * levels_weight[:, 1:2])
        out = self.conv(fused)

        # ✅ 简化残差 (固定gamma)
        return fused + self.gamma * out


class ASFF_3(nn.Module):
    def __init__(self, inter_dim=512):
        super().__init__()
        self.inter_dim = inter_dim
        compress_c = 4

        self.weight_level_1 = BasicConv(inter_dim, compress_c, 1, 1)
        self.weight_level_2 = BasicConv(inter_dim, compress_c, 1, 1)
        self.weight_level_3 = BasicConv(inter_dim, compress_c, 1, 1)
        self.weight_levels = nn.Conv2d(compress_c * 3, 3, 1, 1, 0)

        self.conv = nn.Sequential(
            nn.Conv2d(inter_dim, inter_dim, 3, 1, 1,
                      groups=inter_dim, bias=False),  # DWConv
            nn.BatchNorm2d(inter_dim),
            nn.SiLU(inplace=True),
            nn.Conv2d(inter_dim, inter_dim, 1, bias=False),  # PWConv
            nn.BatchNorm2d(inter_dim),
        )

    def forward(self, input1, input2, input3):
        level_1_weight_v = self.weight_level_1(input1)
        level_2_weight_v = self.weight_level_2(input2)
        level_3_weight_v = self.weight_level_3(input3)
        levels_weight_v = torch.cat((level_1_weight_v, level_2_weight_v, level_3_weight_v), 1)
        levels_weight = F.softmax(self.weight_levels(levels_weight_v), dim=1)

        fused = (input1 * levels_weight[:, 0:1] +
                 input2 * levels_weight[:, 1:2] +
                 input3 * levels_weight[:, 2:3])
        out = self.conv(fused)

        return fused + 0.1 * out


