#  推理专用
def fuse_conv_bn(conv: nn.Conv2d, bn: nn.BatchNorm2d) -> nn.Conv2d:
    bn.eval()
    w = conv.weight
    mean, var, gamma, beta = bn.running_mean, bn.running_var, bn.weight, bn.bias
    std = torch.sqrt(var + bn.eps)
    fused_w = w * (gamma / std).reshape(-1, 1, 1, 1)
    if conv.bias is not None:
        fused_b = (conv.bias - mean) / std * gamma + beta
    else:
        fused_b = (-mean / std) * gamma + beta

    fused = nn.Conv2d(
        conv.in_channels, conv.out_channels,
        conv.kernel_size, conv.stride, conv.padding,
        conv.dilation, conv.groups, bias=True
    )
    fused.weight = nn.Parameter(fused_w)
    fused.bias = nn.Parameter(fused_b)
    return fused


def fuse_sequential_conv_bn(seq: nn.Sequential) -> nn.Sequential:
    layers = list(seq.named_children())
    new_layers = {}
    skip = set()
    for i, (name, layer) in enumerate(layers):
        if i in skip:
            continue
        if (isinstance(layer, nn.Conv2d)
                and i + 1 < len(layers)
                and isinstance(layers[i + 1][1], nn.BatchNorm2d)):
            fused = fuse_conv_bn(layer, layers[i + 1][1])
            new_layers[name] = fused
            skip.add(i + 1)
        else:
            new_layers[name] = layer
    return nn.Sequential(*new_layers.values())


class BasicConv(nn.Module):
    """推理专用：Conv+BN 已折叠，去掉 BN 层。"""

    def __init__(self, conv: nn.Conv2d, use_relu: bool = True):
        super().__init__()
        self.conv = conv
        self.act = nn.ReLU(inplace=True) if use_relu else nn.Identity()

    def forward(self, x):
        return self.act(self.conv(x))

    @staticmethod
    def from_trained(basic_conv: 'BasicConv') -> 'BasicConvInfer':
        net = basic_conv.net
        conv = net.conv
        bn = net.bn
        use_relu = not isinstance(net.relu, nn.Identity)
        fused = fuse_conv_bn(conv, bn)
        return BasicConvInfer(fused, use_relu=use_relu)


class GhostBottleneck(nn.Module):

    def __init__(self,
                 in_channels: int,
                 out_channels: int,
                 stride: int = 1,
                 expansion: float = 2.0,
                 use_se: bool = False,
                 use_simam: bool = False,
                 ghost_ratio: int = 2,
                 dw_kernel: int = 3, ):
        super().__init__()
        assert stride in (1, 2), "GhostBottleneck only supports stride 1 or 2"

        hidden_channels = int(round(in_channels * expansion))
        self.stride = stride
        self.use_simam = use_simam

        # 1) Expand (Ghost)
        self.expand = GhostBasicConv(
            in_channels, hidden_channels,
            kernel_size=1, stride=1, use_relu=True,
            ratio=ghost_ratio
        )

        # 2) Depthwise conv
        dw_pad = (dw_kernel - 1) // 2
        self.dwconv = nn.Sequential(
            nn.Conv2d(hidden_channels, hidden_channels,
                      kernel_size=dw_kernel, stride=stride,
                      padding=dw_pad, groups=hidden_channels, bias=False),
            nn.BatchNorm2d(hidden_channels)
        )

        if use_simam:
            self.simam = C - SimAM()
        else:
            self.simam = nn.Identity()

        self.project = GhostBasicConv(
            hidden_channels, out_channels,
            kernel_size=1, stride=1, use_relu=False,
            ratio=ghost_ratio
        )

        self.shortcut = nn.Identity()
        if (stride != 1) or (in_channels != out_channels):
            self.shortcut = nn.Sequential(
                nn.Conv2d(in_channels, in_channels, dw_kernel, stride=stride,
                          padding=dw_pad, groups=in_channels, bias=False),
                nn.BatchNorm2d(in_channels),
                nn.Conv2d(in_channels, out_channels, 1, 1, 0, bias=False),
                nn.BatchNorm2d(out_channels),
            )

    def forward(self, x):
        out = self.expand(x)
        out = self.dwconv(out)

        out = self.simam(out)

        out = self.se(out)

        out = self.project(out)
        return F.relu(out + self.shortcut(x), inplace=True)


class GhostConv(nn.Module):

    def __init__(self,
                 in_channels: int,
                 out_channels: int,
                 kernel_size: int = 1,
                 stride: int = 1,
                 padding: int | None = None,
                 ratio: int = 2,
                 depthwise_kernel_size: int = 3,
                 relu: bool = True,
                 bias: bool = False):
        super().__init__()

        assert ratio >= 1, "ratio must be >= 1"
        self.out_channels = out_channels

        if padding is None:
            padding = (kernel_size - 1) // 2

        init_channels = int(out_channels / ratio)
        cheap_channels = out_channels - init_channels

        self.primary = nn.Sequential(
            nn.Conv2d(in_channels, init_channels,
                      kernel_size=kernel_size,
                      stride=stride,
                      padding=padding,
                      bias=bias),
            nn.BatchNorm2d(init_channels),
            nn.ReLU(inplace=True) if relu else nn.Identity()
        )

        dw_pad = (depthwise_kernel_size - 1) // 2
        self.cheap = nn.Sequential(
            nn.Conv2d(init_channels, cheap_channels,
                      kernel_size=depthwise_kernel_size,
                      stride=1,
                      padding=dw_pad,
                      groups=init_channels,
                      bias=bias),
            nn.BatchNorm2d(cheap_channels),
            nn.ReLU(inplace=True) if relu else nn.Identity()
        )

    def forward(self, x):
        x_p = self.primary(x)
        x_c = self.cheap(x_p)
        return torch.cat([x_p, x_c], dim=1)


class GhostBasicConv(nn.Module):
    """ GhostConv + BN + Act """

    def __init__(self,
                 in_channels: int,
                 out_channels: int,
                 kernel_size: int = 1,
                 stride: int = 1,
                 padding: int | None = None,
                 use_relu: bool = True,
                 bias: bool = False,
                 ratio: int = 2,
                 depthwise_kernel_size: int = 3):
        super().__init__()
        if padding is None:
            padding = (kernel_size - 1) // 2
        self.layers = nn.Sequential(
            GhostConv(in_channels, out_channels,
                      kernel_size=kernel_size,
                      stride=stride,
                      padding=padding,
                      ratio=ratio,
                      depthwise_kernel_size=depthwise_kernel_size,
                      relu=False,
                      bias=bias),
            nn.BatchNorm2d(out_channels),
            nn.ReLU(inplace=True) if use_relu else nn.Identity()
        )

    def forward(self, x):
        return self.layers(x)


class BasicBlock(nn.Module):
    """
    conv3x3 → bn/relu → ghost3x3 → bn → +proj(residual) → relu
    """

    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.conv1 = BasicConv(in_channels, out_channels, kernel_size=3, stride=1, use_relu=True)
        self.conv2 = GhostBasicConv(out_channels, out_channels, kernel_size=3, stride=1, use_relu=False)

        self.proj = None
        if in_channels != out_channels:
            self.proj = nn.Sequential(
                nn.Conv2d(in_channels, out_channels, kernel_size=1, bias=False),
                nn.BatchNorm2d(out_channels)
            )

    def forward(self, x):
        residual = x if self.proj is None else self.proj(x)
        out = self.conv1(x)
        out = self.conv2(out)
        assert out.shape == residual.shape, f"Shape mismatch: out={out.shape}, res={residual.shape}"
        out += residual
        return F.relu(out, inplace=True)


